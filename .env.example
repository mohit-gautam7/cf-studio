# ---- AI provider (pick ONE block; uncomment/fill it) ----------------------
# Model lists change — verified current as of July 2026.

# Option 1 (default, recommended): OpenRouter — free key at https://openrouter.ai/keys
AI_API_KEY=
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
# faster free alternative:  AI_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Option 2: Groq — free key at https://console.groq.com/keys
#AI_BASE_URL=https://api.groq.com/openai/v1
#AI_MODEL=openai/gpt-oss-120b

# Option 3: NVIDIA NIM — free key at https://build.nvidia.com (pick a model page -> Get API Key)
#AI_BASE_URL=https://integrate.api.nvidia.com/v1
#AI_MODEL=<model id shown on the model page>

# Option 4: fully local via Ollama — no key at all
#AI_BASE_URL=http://localhost:11434/v1
#AI_MODEL=qwen2.5-coder

# ---- Judge ----------------------------------------------------------------
# Default: free public Piston API (rate-limited). Self-host for speed:
#PISTON_URL=http://localhost:2000/api/v2/piston
# EXECUTOR=local runs code with YOUR local toolchain, unsandboxed. Own code only.
#EXECUTOR=local

# ---- Server ---------------------------------------------------------------
#PORT=8000
#HOST=127.0.0.1
