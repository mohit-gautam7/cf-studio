# ---- AI keys: add ANY OR ALL. CF Studio tries the best model first and
# ---- automatically falls back to the next provider on any error.
# Priority: OpenRouter (Nemotron 3 Ultra free, 1M ctx) -> NVIDIA NIM (same model)
#           -> Groq (gpt-oss-120b, fastest). Verified July 2026.

# free key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# free key: https://console.groq.com/keys
GROQ_API_KEY=

# free key: https://build.nvidia.com  (open a model page -> Get API Key)
NVIDIA_API_KEY=

# optional model overrides:
#OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
#NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b
#GROQ_MODEL=openai/gpt-oss-120b

# optional custom/local provider (e.g. Ollama) — used FIRST when set:
#AI_BASE_URL=http://localhost:11434/v1
#AI_MODEL=qwen2.5-coder

# back-compat: AI_API_KEY alone still works and is treated as the OpenRouter key.

# ---- Judge ----------------------------------------------------------------
# Default: free public Piston API (rate-limited). Self-host for speed:
#PISTON_URL=http://localhost:2000/api/v2/piston
# EXECUTOR=local runs code with YOUR local toolchain, unsandboxed. Own code only.
#EXECUTOR=local

# ---- Server ---------------------------------------------------------------
#PORT=8000
#HOST=127.0.0.1
